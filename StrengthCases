        .audit-area {
            width: 100%;
            max-width: 800px;
            background: var(--card-bg);
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            padding: 30px;
        }
        .audit-area h3 {
            margin-top: 0;
            color: #4a5568;
        }
        textarea {
            width: 100%;
            height: 120px;
            padding: 15px;
